resource app_signature "application/x-vnd.NFSMount";

resource app_flags B_SINGLE_LAUNCH;

resource app_version {
	major  = 0,
	middle = 0,
	minor  = 4,

	variety = B_APPV_ALPHA,
	internal = 1,

	short_info = "NFSMount",
	long_info = "NFS Share Manager for Haiku"
};

resource(1, "BEOS:FILE_TYPES") message {
	"types" = "application/x-vnd.NFSMount"
};

